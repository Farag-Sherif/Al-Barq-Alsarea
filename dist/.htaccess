<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Keep real files/directories accessible.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback: send all client routes to index.html.
  RewriteRule ^ index.html [L]
</IfModule>
