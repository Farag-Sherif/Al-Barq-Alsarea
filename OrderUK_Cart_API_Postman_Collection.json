{
    "info": {
        "name": "OrderUK Cart API",
        "description": "Cart Endpoints",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000/api",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Cart",
            "item": [
                {
                    "name": "Get Cart",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/cart",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Add to Cart",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/add",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"restaurant_id\": 1,\n    \"menu_item_id\": 1,\n    \"quantity\": 2,\n    \"notes\": \"Extra spicy\",\n    \"addons\": [1, 2]\n}"
                        }
                    }
                },
                {
                    "name": "Update Cart Item",
                    "request": {
                        "method": "PUT",
                        "url": "{{base_url}}/cart/item/1",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"quantity\": 3,\n    \"notes\": \"Updated notes\"\n}"
                        }
                    }
                },
                {
                    "name": "Remove Cart Item",
                    "request": {
                        "method": "DELETE",
                        "url": "{{base_url}}/cart/item/1",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Clear Cart",
                    "request": {
                        "method": "DELETE",
                        "url": "{{base_url}}/cart/clear",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                },
                {
                    "name": "Checkout",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/cart/checkout",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"address_id\": 1,\n    \"payment_method\": \"cash\",\n    \"notes\": \"No onions please\",\n    \"promo_code\": \"DISCOUNT10\"\n}"
                        }
                    }
                }
            ]
        }
    ]
}
