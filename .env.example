## Data source mode:
## - api: always live API
## - mock: always static dummy data
## - hybrid: try API, then fallback to mock on failure
VITE_DATA_SOURCE=hybrid

# Backward compatibility (still supported if VITE_DATA_SOURCE is not set)
VITE_API_MODE=hybrid
VITE_API_BASE_URL=https://food.test.do-go.net/api
VITE_API_STORAGE_BASE_URL=https://food.test.do-go.net/storage/
VITE_API_LOG=true

# Optional endpoints for cart/favorites if your backend uses custom paths.
# Comma-separated values are supported. The app will try these paths in order.
# VITE_CART_GET_PATHS=/cart,/cart/items
# VITE_CART_ADD_PATHS=/cart/add,/cart/items,/cart
# VITE_CART_UPDATE_PATHS=/cart/item/{id},/cart/items/{id},/cart/{id}
# VITE_CART_REMOVE_PATHS=/cart/item/{id},/cart/items/{id},/cart/{id}
# VITE_CART_CLEAR_PATHS=/cart/clear,/cart
# VITE_CHECKOUT_PATHS=/orders,/cart/checkout
# VITE_FAVORITES_GET_PATHS=/favorites,/wishlist
# VITE_FAVORITES_ADD_PATHS=/favorites,/favorites/add,/wishlist,/wishlist/add
# VITE_FAVORITES_REMOVE_PATHS=/favorites/{id},/favorites/remove/{id},/wishlist/{id},/wishlist/remove/{id}
# VITE_BRANCHES_GET_PATHS=/branches
# VITE_RESTAURANT_STATES_PATHS=/restaurants/{id}/states
